```bash
# Vérifier la syntaxe du chart (lint)
helm lint ./postgresdb

# Afficher les manifests générés sans rien appliquer
helm template postgresdb ./postgresdb 
  --namespace postgres

# Dry-run avec debug pour simuler l'installation
helm install postgresdb ./postgresdb 
  -n postgres 
  --create-namespace 
  --dry-run --debug
```

